
package layout

templ Base() {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Go on Rails</title>

			<!-- Primary Meta Tags -->
			<title>Go on Rails</title>
			<meta name="title" content="Go on Rails" />
			<meta name="description" content="A starter kit for Go, not a framework, resembling patterns found in Rails and other MVC frameworks." />

			<!-- Open Graph / Facebook -->
			<meta property="og:type" content="website" />
			<meta property="og:url" content="https://GoOnRails.com/" />
			<meta property="og:title" content="Go on Rails" />
			<meta property="og:description" content="A starter kit for Go, not a framework, resembling patterns found in Rails and other MVC frameworks." />
			<meta property="og:image" content="https://GoOnRails.com/glyphs.png" />

			<!-- Twitter -->
			<meta property="twitter:card" content="summary_large_image" />
			<meta property="twitter:url" content="https://GoOnRails.com/" />
			<meta property="twitter:title" content="Go on Rails" />
			<meta property="twitter:description" content="A starter kit for Go, not a framework, resembling patterns found in Rails and other MVC frameworks." />
			<meta property="twitter:image" content="https://GoOnRails.com/glyphs.png" />


			<script src="https://unpkg.com/htmx.org@1.9.9"></script>
			<script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>
		</head>
		<body>
			<header>
				<nav class="p-6 mx-auto">
					<div class="flex justify-between items-center">
						<a href="/" class="text-2xl font-bold">Go on Rails</a>
						<div>
							<a href="/login" class="mr-4">Login</a>
							<a href="/signup">Signup</a>
						</div>
					</div>

				</nav>
			</header>
			{ children... }
		</body>
	</html>
}
